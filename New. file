<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Shuddh Swad — Pure & Authentic Thekua</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet"/>
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --white: #FAFAF8;
    --cream: #F4F1EB;
    --sand: #E8E2D5;
    --stone: #C9C0B0;
    --bark: #6B5E4C;
    --deep: #2A2318;
    --gold: #B8A47A;
    --gold-light: #D4C49A;
    --accent: #8B6F47;
  }

  html { scroll-behavior: smooth; }

  body {
    background: var(--white);
    color: var(--deep);
    font-family: 'DM Sans', sans-serif;
    font-weight: 300;
    overflow-x: hidden;
  }

  /* ── ANNOUNCEMENT BAR ── */
  .announce {
    background: var(--deep);
    color: var(--gold-light);
    text-align: center;
    padding: 10px 20px;
    font-size: 12px;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    font-weight: 400;
  }

  /* ── NAV ── */
  nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(250,250,248,0.95);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--sand);
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 48px;
    height: 70px;
  }

  .nav-logo {
    font-family: 'Cormorant Garamond', serif;
    font-size: 24px;
    font-weight: 600;
    letter-spacing: 1px;
    color: var(--deep);
    text-decoration: none;
  }
  .nav-logo span { color: var(--gold); }

  .nav-links {
    display: flex;
    gap: 36px;
    list-style: none;
  }
  .nav-links a {
    font-size: 12px;
    letter-spacing: 1.8px;
    text-transform: uppercase;
    color: var(--bark);
    text-decoration: none;
    transition: color 0.25s;
  }
  .nav-links a:hover { color: var(--deep); }

  .nav-cta {
    background: var(--deep);
    color: var(--gold-light) !important;
    padding: 10px 22px;
    border-radius: 2px;
    transition: background 0.25s !important;
  }
  .nav-cta:hover { background: var(--accent) !important; color: #fff !important; }

  /* ── HERO ── */
  .hero {
    position: relative;
    min-height: 96vh;
    display: grid;
    grid-template-columns: 1fr 1fr;
    overflow: hidden;
  }

  .hero-left {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 80px 64px 80px 80px;
    background: var(--white);
    position: relative;
    z-index: 2;
  }

  .hero-eyebrow {
    font-size: 11px;
    letter-spacing: 4px;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 24px;
    display: flex;
    align-items: center;
    gap: 12px;
    opacity: 0;
    animation: fadeUp 0.8s 0.2s forwards;
  }
  .hero-eyebrow::before {
    content: '';
    display: block;
    width: 32px;
    height: 1px;
    background: var(--gold);
  }

  .hero-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(52px, 5.5vw, 82px);
    font-weight: 300;
    line-height: 1.08;
    color: var(--deep);
    margin-bottom: 28px;
    opacity: 0;
    animation: fadeUp 0.9s 0.35s forwards;
  }
  .hero-title em {
    font-style: italic;
    color: var(--accent);
  }

  .hero-desc {
    font-size: 16px;
    line-height: 1.75;
    color: var(--bark);
    max-width: 420px;
    margin-bottom: 48px;
    font-weight: 300;
    opacity: 0;
    animation: fadeUp 0.9s 0.5s forwards;
  }

  .hero-actions {
    display: flex;
    gap: 16px;
    align-items: center;
    opacity: 0;
    animation: fadeUp 0.9s 0.65s forwards;
  }

  .btn-primary {
    background: var(--deep);
    color: var(--gold-light);
    padding: 16px 36px;
    font-size: 12px;
    letter-spacing: 2px;
    text-transform: uppercase;
    border: none;
    cursor: pointer;
    text-decoration: none;
    display: inline-block;
    transition: background 0.3s, transform 0.2s;
  }
  .btn-primary:hover { background: var(--accent); transform: translateY(-1px); }

  .btn-ghost {
    color: var(--bark);
    font-size: 12px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    text-decoration: none;
    padding: 16px 0;
    border-bottom: 1px solid var(--stone);
    transition: color 0.25s, border-color 0.25s;
  }
  .btn-ghost:hover { color: var(--deep); border-color: var(--deep); }

  .hero-stats {
    display: flex;
    gap: 40px;
    margin-top: 64px;
    padding-top: 40px;
    border-top: 1px solid var(--sand);
    opacity: 0;
    animation: fadeUp 0.9s 0.8s forwards;
  }
  .stat-num {
    font-family: 'Cormorant Garamond', serif;
    font-size: 36px;
    font-weight: 300;
    color: var(--deep);
    line-height: 1;
  }
  .stat-label {
    font-size: 11px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--stone);
    margin-top: 4px;
  }

  .hero-right {
    position: relative;
    background: var(--cream);
    overflow: hidden;
  }

  .hero-img-wrap {
    position: absolute;
    inset: 0;
    opacity: 0;
    animation: fadeIn 1.2s 0.3s forwards;
  }

  .hero-img-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .hero-badge {
    position: absolute;
    bottom: 48px;
    left: -28px;
    background: var(--white);
    border: 1px solid var(--sand);
    padding: 20px 24px;
    z-index: 3;
    box-shadow: 0 8px 40px rgba(42,35,24,0.1);
    opacity: 0;
    animation: fadeUp 0.8s 1s forwards;
  }
  .hero-badge-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: 18px;
    font-weight: 600;
    color: var(--deep);
  }
  .hero-badge-sub {
    font-size: 11px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--stone);
    margin-top: 2px;
  }

  .hero-tag {
    position: absolute;
    top: 40px;
    right: 40px;
    background: var(--deep);
    color: var(--gold-light);
    padding: 12px 18px;
    font-size: 11px;
    letter-spacing: 2px;
    text-transform: uppercase;
    z-index: 3;
    opacity: 0;
    animation: fadeIn 0.8s 1.2s forwards;
  }

  .hero-scroll {
    position: absolute;
    bottom: 36px;
    left: 80px;
    display: flex;
    align-items: center;
    gap: 12px;
    font-size: 11px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--stone);
    opacity: 0;
    animation: fadeIn 1s 1.4s forwards;
  }
  .scroll-line {
    width: 40px;
    height: 1px;
    background: var(--stone);
    position: relative;
    overflow: hidden;
  }
  .scroll-line::after {
    content: '';
    position: absolute;
    top: 0; left: -100%;
    width: 100%; height: 100%;
    background: var(--gold);
    animation: slideLine 1.5s 2s infinite;
  }

  /* ── MARQUEE ── */
  .marquee-wrap {
    background: var(--deep);
    padding: 18px 0;
    overflow: hidden;
  }
  .marquee-track {
    display: flex;
    gap: 0;
    animation: marquee 22s linear infinite;
    white-space: nowrap;
  }
  .marquee-item {
    display: inline-flex;
    align-items: center;
    gap: 24px;
    padding: 0 32px;
    font-size: 11px;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--gold-light);
    font-weight: 400;
  }
  .marquee-dot {
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: var(--gold);
    flex-shrink: 0;
  }

  /* ── TRUST BAR ── */
  .trust-bar {
    padding: 48px 80px;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0;
    border-bottom: 1px solid var(--sand);
  }
  .trust-item {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 0 32px;
    border-right: 1px solid var(--sand);
  }
  .trust-item:first-child { padding-left: 0; }
  .trust-item:last-child { border-right: none; }
  .trust-icon {
    width: 44px;
    height: 44px;
    background: var(--cream);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 18px;
    flex-shrink: 0;
  }
  .trust-title {
    font-size: 13px;
    font-weight: 500;
    color: var(--deep);
    margin-bottom: 2px;
  }
  .trust-sub {
    font-size: 11px;
    color: var(--stone);
    letter-spacing: 0.5px;
  }

  /* ── PRODUCTS ── */
  .products {
    padding: 100px 80px;
    background: var(--white);
  }
  .section-header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    margin-bottom: 64px;
  }
  .section-eyebrow {
    font-size: 11px;
    letter-spacing: 3.5px;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 12px;
  }
  .section-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(36px, 3.5vw, 52px);
    font-weight: 300;
    line-height: 1.1;
    color: var(--deep);
  }
  .section-title em { font-style: italic; color: var(--accent); }
  .view-all {
    font-size: 11px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--bark);
    text-decoration: none;
    border-bottom: 1px solid var(--stone);
    padding-bottom: 2px;
    transition: color 0.2s, border-color 0.2s;
    white-space: nowrap;
    margin-bottom: 6px;
  }
  .view-all:hover { color: var(--deep); border-color: var(--deep); }

  .products-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2px;
  }

  .product-card {
    background: var(--cream);
    position: relative;
    overflow: hidden;
    cursor: pointer;
    group: true;
  }
  .product-img {
    aspect-ratio: 4/5;
    overflow: hidden;
    position: relative;
  }
  .product-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.7s cubic-bezier(0.25,0.46,0.45,0.94);
  }
  .product-card:hover .product-img img { transform: scale(1.06); }

  .product-sale {
    position: absolute;
    top: 20px;
    left: 20px;
    background: var(--deep);
    color: var(--gold-light);
    font-size: 10px;
    letter-spacing: 2px;
    text-transform: uppercase;
    padding: 6px 12px;
  }

  .product-info {
    padding: 24px 28px 28px;
  }
  .product-name {
    font-family: 'Cormorant Garamond', serif;
    font-size: 22px;
    font-weight: 400;
    color: var(--deep);
    margin-bottom: 8px;
    line-height: 1.2;
  }
  .product-prices {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 16px;
  }
  .price-current {
    font-size: 18px;
    font-weight: 500;
    color: var(--deep);
  }
  .price-old {
    font-size: 14px;
    color: var(--stone);
    text-decoration: line-through;
  }
  .price-save {
    font-size: 10px;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: var(--accent);
    background: rgba(139,111,71,0.1);
    padding: 3px 8px;
    border-radius: 1px;
  }
  .product-btn {
    width: 100%;
    background: transparent;
    border: 1px solid var(--deep);
    color: var(--deep);
    padding: 12px;
    font-size: 11px;
    letter-spacing: 2px;
    text-transform: uppercase;
    cursor: pointer;
    transition: background 0.25s, color 0.25s;
    font-family: 'DM Sans', sans-serif;
  }
  .product-btn:hover { background: var(--deep); color: var(--gold-light); }

  /* Combo card larger */
  .product-card.featured {
    grid-column: span 1;
    background: var(--deep);
  }
  .product-card.featured .product-info { background: var(--deep); }
  .product-card.featured .product-name { color: var(--gold-light); }
  .product-card.featured .price-current { color: var(--gold-light); }
  .product-card.featured .price-old { color: var(--stone); }
  .product-card.featured .product-btn {
    border-color: var(--gold);
    color: var(--gold-light);
  }
  .product-card.featured .product-btn:hover {
    background: var(--gold);
    color: var(--deep);
  }

  /* ── STORY ── */
  .story {
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: 640px;
  }
  .story-img {
    position: relative;
    overflow: hidden;
  }
  .story-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .story-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(42,35,24,0.3) 0%, transparent 60%);
  }
  .story-content {
    background: var(--cream);
    padding: 80px 80px 80px 72px;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  .story-content .section-eyebrow { margin-bottom: 16px; }
  .story-content .section-title { margin-bottom: 24px; }
  .story-body {
    font-size: 16px;
    line-height: 1.8;
    color: var(--bark);
    margin-bottom: 32px;
    max-width: 440px;
  }
  .founders-row {
    display: flex;
    gap: 24px;
    margin-top: 40px;
    padding-top: 36px;
    border-top: 1px solid var(--sand);
  }
  .founder-card {
    display: flex;
    align-items: center;
    gap: 14px;
  }
  .founder-avatar {
    width: 52px;
    height: 52px;
    border-radius: 50%;
    object-fit: cover;
    border: 2px solid var(--gold-light);
  }
  .founder-name {
    font-family: 'Cormorant Garamond', serif;
    font-size: 16px;
    font-weight: 600;
    color: var(--deep);
  }
  .founder-role {
    font-size: 11px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--stone);
    margin-top: 2px;
  }

  /* ── VALUES ── */
  .values {
    padding: 100px 80px;
    background: var(--white);
  }
  .values .section-header { margin-bottom: 64px; }
  .values-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2px;
  }
  .value-card {
    background: var(--cream);
    padding: 40px 32px;
    border-bottom: 3px solid transparent;
    transition: border-color 0.3s, background 0.3s;
  }
  .value-card:hover { border-color: var(--gold); background: var(--sand); }
  .value-icon {
    font-size: 28px;
    margin-bottom: 20px;
    display: block;
  }
  .value-name {
    font-family: 'Cormorant Garamond', serif;
    font-size: 22px;
    font-weight: 400;
    color: var(--deep);
    margin-bottom: 12px;
  }
  .value-desc {
    font-size: 14px;
    line-height: 1.65;
    color: var(--bark);
  }

  /* ── REVIEWS ── */
  .reviews {
    padding: 100px 80px;
    background: var(--deep);
  }
  .reviews .section-eyebrow { color: var(--gold-light); }
  .reviews .section-title { color: var(--white); margin-bottom: 16px; }
  .reviews-sub {
    font-size: 15px;
    color: var(--stone);
    margin-bottom: 64px;
    max-width: 480px;
  }
  .reviews-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2px;
  }
  .review-card {
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.07);
    padding: 36px;
    transition: background 0.3s;
  }
  .review-card:hover { background: rgba(255,255,255,0.07); }
  .review-stars {
    color: var(--gold);
    font-size: 14px;
    letter-spacing: 2px;
    margin-bottom: 16px;
  }
  .review-text {
    font-family: 'Cormorant Garamond', serif;
    font-size: 18px;
    font-style: italic;
    color: rgba(250,250,248,0.85);
    line-height: 1.55;
    margin-bottom: 24px;
  }
  .review-author {
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .review-avatar {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    object-fit: cover;
    border: 1px solid rgba(184,164,122,0.3);
  }
  .review-name {
    font-size: 13px;
    font-weight: 500;
    color: var(--gold-light);
  }
  .review-date {
    font-size: 11px;
    color: var(--stone);
    margin-top: 2px;
  }

  /* ── MEDIA ── */
  .media {
    padding: 80px 80px;
    background: var(--cream);
    border-top: 1px solid var(--sand);
    border-bottom: 1px solid var(--sand);
  }
  .media-label {
    text-align: center;
    font-size: 11px;
    letter-spacing: 4px;
    text-transform: uppercase;
    color: var(--stone);
    margin-bottom: 48px;
  }
  .media-logos {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
    gap: 40px 56px;
  }
  .media-logo {
    height: 28px;
    object-fit: contain;
    filter: grayscale(100%) opacity(0.45);
    transition: filter 0.3s;
  }
  .media-logo:hover { filter: grayscale(0%) opacity(1); }

  /* ── PLATFORMS ── */
  .platforms {
    padding: 80px 80px;
    background: var(--white);
    text-align: center;
  }
  .platforms .section-eyebrow { display: block; text-align: center; margin-bottom: 12px; }
  .platforms .section-title { text-align: center; margin-bottom: 48px; }
  .platforms-row {
    display: flex;
    justify-content: center;
    gap: 32px;
  }
  .platform-card {
    background: var(--cream);
    border: 1px solid var(--sand);
    padding: 28px 44px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    text-decoration: none;
    transition: border-color 0.3s, box-shadow 0.3s, transform 0.2s;
  }
  .platform-card:hover {
    border-color: var(--gold);
    box-shadow: 0 8px 32px rgba(184,164,122,0.15);
    transform: translateY(-3px);
  }
  .platform-card img {
    height: 36px;
    object-fit: contain;
  }
  .platform-label {
    font-size: 11px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--bark);
  }

  /* ── FOOTER ── */
  footer {
    background: var(--deep);
    padding: 80px 80px 40px;
  }
  .footer-top {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1.5fr;
    gap: 64px;
    padding-bottom: 64px;
    border-bottom: 1px solid rgba(255,255,255,0.08);
    margin-bottom: 40px;
  }
  .footer-brand-name {
    font-family: 'Cormorant Garamond', serif;
    font-size: 28px;
    font-weight: 300;
    color: var(--white);
    margin-bottom: 16px;
  }
  .footer-brand-name span { color: var(--gold); }
  .footer-desc {
    font-size: 14px;
    line-height: 1.7;
    color: var(--stone);
    margin-bottom: 28px;
    max-width: 280px;
  }
  .footer-social {
    display: flex;
    gap: 12px;
  }
  .social-link {
    width: 36px; height: 36px;
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.1);
    display: flex; align-items: center; justify-content: center;
    color: var(--stone);
    font-size: 12px;
    text-decoration: none;
    transition: background 0.25s, color 0.25s, border-color 0.25s;
    font-weight: 500;
  }
  .social-link:hover {
    background: var(--gold);
    color: var(--deep);
    border-color: var(--gold);
  }
  .footer-col-title {
    font-size: 11px;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    color: var(--gold-light);
    margin-bottom: 24px;
  }
  .footer-links { list-style: none; }
  .footer-links li { margin-bottom: 12px; }
  .footer-links a {
    font-size: 14px;
    color: var(--stone);
    text-decoration: none;
    transition: color 0.2s;
  }
  .footer-links a:hover { color: var(--white); }
  .footer-contact-item {
    display: flex;
    gap: 12px;
    margin-bottom: 16px;
    font-size: 14px;
    color: var(--stone);
    line-height: 1.5;
  }
  .footer-contact-item a { color: var(--stone); text-decoration: none; transition: color 0.2s; }
  .footer-contact-item a:hover { color: var(--gold-light); }
  .footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .footer-copy {
    font-size: 12px;
    color: rgba(201,192,176,0.5);
    letter-spacing: 0.5px;
  }
  .footer-copy span { color: var(--gold); }

  /* ── ANIMATIONS ── */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(24px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  @keyframes fadeIn {
